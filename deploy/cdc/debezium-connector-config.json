{
  "name": "erp-postgres-connector",
  "config": {
    "connector.class": "io.debezium.connector.postgresql.PostgresConnector",
    "database.hostname": "${DB_HOST:postgres}",
    "database.port": "${DB_PORT:5432}",
    "database.user": "${DB_USER:erp}",
    "database.password": "${DB_PASSWORD:erp}",
    "database.dbname": "${DB_NAME:erp}",
    "database.server.name": "erp",
    "plugin.name": "pgoutput",
    "slot.name": "erp_debezium",
    "slot.drop.on.stop": false,
    "publication.name": "erp_publication",
    "publication.autocreate.mode": "filtered",
    "schema.include.list": "iam,pdm,som,oms,scm,wms,tms,fms,ads,crm,fba,bi,sys,dashboard",
    "table.exclude.list": "sys.cdc_event_record,sys.connector_call_log,sys.outbox_message",
    "column.exclude.list": "sys.connector_config.auth_config_json,sys.secret_store.encrypted_value",
    "snapshot.mode": "initial",
    "snapshot.lock.timeout.ms": "10000",
    "snapshot.fetch.size": "2000",
    "tombstones.on.delete": false,
    "decimal.handling.mode": "string",
    "time.precision.mode": "connect",
    "include.unknown.datatypes": true,
    "database.history.kafka.bootstrap.servers": "${KAFKA_BOOTSTRAP:kafka:9092}",
    "database.history.kafka.topic": "schema-changes.erp",
    "database.history.kafka.recovery.attempts": "6",
    "database.history.kafka.recovery.poll.interval.ms": "2000",
    "database.tcpkeepalive": true,
    "database.sslmode": "prefer",
    "heartbeat.interval.ms": "60000",
    "heartbeat.topics.prefix": "__debezium-heartbeat",
    "skipped.operations": "n",
    "max.queue.size": "8192",
    "max.batch.size": "2048",
    "poll.interval.ms": "500",
    "retrieve.inherited.columns": false,
    "message.key.columns": "iam.users:id;pdm.products:id;oms.orders:id;wms.inventory:id;fms.cost_event:id;scm.purchase_orders:id;tms.shipments:id",
    "transforms": "unwrap,addTenant",
    "transforms.unwrap.type": "io.debezium.transforms.ExtractNewRecordState",
    "transforms.unwrap.drop.tombstones": true,
    "transforms.unwrap.delete.handling.mode": "rewrite",
    "transforms.unwrap.add.fields": "op,ts_ms,source.table,source.schema",
    "transforms.addTenant.type": "org.apache.kafka.connect.transforms.InsertField$Value",
    "transforms.addTenant.static.field": "cdc_source",
    "transforms.addTenant.static.value": "debezium-pg-erp"
  }
}
